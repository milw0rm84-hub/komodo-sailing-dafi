# Railway Deployment - Set these in Railway Dashboard
# Go to your Railway project -> Variables

PORT=5000

# MySQL Database (use Railway MySQL or external)
DB_HOST=containers.uconn.edu.au
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=komodo_sailing

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES=7d

# Frontend URL (update after deploying Vercel)
FRONTEND_URL=https://your-app.vercel.app

# Admin default credentials (change after first login)
ADMIN_EMAIL=admin@komodosailing.com
ADMIN_PASSWORD=komodo123
